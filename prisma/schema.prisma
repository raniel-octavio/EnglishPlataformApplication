datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      String   // "teacher" ou "student"
  classes   Class[]  @relation("UserClasses")
}

model Class {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  teacher     User     @relation("UserClasses", fields: [teacherId], references: [id])
  teacherId   Int
  students    User[]   @relation("ClassStudents")
  date        DateTime
}
